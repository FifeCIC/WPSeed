<?xml version="1.0"?>
<ruleset name="WPSeed">
    <description>WordPress Coding Standards for WPSeed Plugin</description>
    
    <!-- Include the WordPress-Extra standard. -->
    <rule ref="WordPress-Extra">
        <!-- Allow for theme/plugin specific exceptions -->
        <exclude name="WordPress.Files.FileName.InvalidClassFileName" />
        <exclude name="WordPress.Files.FileName.NotHyphenatedLowercase" />
    </rule>

    <!-- Include the WordPress-Docs standard. -->
    <rule ref="WordPress-Docs" />

    <!-- Let's also check that everything is properly documented. -->
    <rule ref="WordPress-Extra">
        <exclude name="WordPress.PHP.YodaConditions.NotYoda" />
    </rule>

    <!-- Check for PHP cross-version compatibility. -->
    <config name="testVersion" value="7.4-"/>
    <rule ref="PHPCompatibilityWP"/>

    <!-- Exclude third-party libraries -->
    <exclude-pattern>*/includes/libraries/*</exclude-pattern>
    <exclude-pattern>*/vendor/*</exclude-pattern>
    <exclude-pattern>*/node_modules/*</exclude-pattern>
    
    <!-- Exclude minified files -->
    <exclude-pattern>*.min.js</exclude-pattern>
    <exclude-pattern>*.min.css</exclude-pattern>
    
    <!-- Allow development functions in example files -->
    <rule ref="WordPress.PHP.DevelopmentFunctions">
        <exclude-pattern>*/examples/*</exclude-pattern>
    </rule>
    
    <!-- Set the minimum supported WP version -->
    <config name="minimum_supported_wp_version" value="5.0"/>
    
    <!-- Check all PHP files in directory tree by default. -->
    <arg name="extensions" value="php"/>
    <file>.</file>

    <!-- Show sniff codes in all reports -->
    <arg value="ps"/>

    <!-- Show progress and sniff codes -->
    <arg name="colors"/>
    <arg name="parallel" value="8"/>
</ruleset>